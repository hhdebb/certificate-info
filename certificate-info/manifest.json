{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "version": "0.3.0",

  "icons": {
    "16": "icon_16.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  },

  "action": {
    "default_icon": "ic_lock.png",
    "default_popup": "popup.html",
    "default_title": "__MSG_appName__"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "https://api.blupig.net/*"
  ]
}
